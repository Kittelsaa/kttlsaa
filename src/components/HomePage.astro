---
import HomeButton from './HomeButton.astro';
---

<section class="home-section">
  <div class="container">
    <div class="intro-section">
      <h1 style="font-family: 'Averia Serif Libre', serif; font-weight: 400;" class="main-title">Hello, I'm Kittelsaa</h1>
      <p class="intro-text">
        My digital garden is a living ecosystem of ideas, explorations & essays, from emerging seedlings of thought to fully grown trees. 
      </p>
      <div class="cta-buttons">
        <HomeButton href="/garden" variant="secondary" >
          <span style="var(--font-body);">Browse The Garden</span>
        </HomeButton>
        <HomeButton href="/about" variant="primary" class="connect-button">
          <span style="var(--font-body);">Let's Connect</span>
        </HomeButton>
      </div>
    </div>
    
    <div class="content-grid">
      <div class="subsection resources-section">
        <h2 class="section-title">Resources & Guides</h2>
        <div class="collections-table">
          <div class="resources-grid">
            <!-- <div class="collection-item">
              <h3 class="item-title">Ikitabo Base</h3>
              <p class="item-desc">...</p>
              <a href="https://base.ikitabo.com/" class="view-link">View Website</a>
            </div> -->
            <div class="collection-item">
              <h3 class="item-title">Note-Taking Guide</h3>
              <p class="item-desc">A practical guide to help transform your note-taking process, leading to more intuitive & creative discoveries.</p>
              <a href="https://taking-notes-guide.kttlsaa.com/" class="view-link">View Guide</a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="subsection subscribe-section">
        <h2 class="section-title-description">Want to stay up to date? </h2>
        <!-- <p class="rss-description">
          Want to stay up to date? 
        </p> -->
        <!-- <div class="rss-url-box">
          <span class="rss-url-text">https://www.kttlsaa.com/rss.xml</span>
        </div> -->
        <a href="/rss.xml" class="rss-button">
          Subscribe via RSS
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .container {
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 6rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .main-title {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  
  .intro-text {
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }
  
  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 70%) minmax(0, 30%);
    gap: 1rem;
    margin-bottom: 3rem;
  }
  
  .resources-section {
    margin-bottom: 0rem;
  }
  
  .section-title {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: var(--color-text);
    font-family: var(--font-heading);
  }
  
  .collections-table {
    border: 1px solid var(--color-border);
    background-color: var(--background-color);
    overflow: hidden;
  }
  
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    width: 100%;
  }
  
  .collection-item {
    padding: 1.5rem;
    background-color: var(--background-color);
    transition: all 0.2s ease;
    border: 0;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }
  
  .collection-item:nth-child(2n) {
    border-right: none;
  }
  
  .collection-item:nth-last-child(-n+2) {
    border-bottom: none;
  }
  
  .item-title {
    margin-bottom: 0.75rem;
    font-weight: normal;
    font-family: var(--font-heading);
  }
  
  .item-desc {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  
  .view-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-accent-2);
    text-decoration: none;
    font-weight: 500;
  }
  
  .view-link:hover {
    text-decoration: underline;
  }
  
  /* Subscribe Section */
  .subscribe-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-left: 2.5rem;
  }

  .section-title-description {
    font-size: 1.1rem;
    margin-bottom: 0;
    letter-spacing: 0.05em;
    color: var(--color-text);
    font-weight: 600;
  }

  .rss-description {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .rss-url-box {
    border: 1px solid var(--color-border);
    padding: 0.65rem 1rem;
    background-color: var(--background-color);
  }

  .rss-url-text {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: monospace;
    word-break: break-all;
  }

  .rss-button {
    display: inline-block;
    background-color: var(--color-accent-2);
    color: black;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: 'Averia Serif Libre', serif;
    text-align: center;
    transition: opacity 0.2s ease;
    max-width: 200px;
  }

  @media (max-width: 1024px) {
    .main-title {
      font-size: 2.5rem;
    }
    
    .intro-text {
      font-size: 1.1rem;
    }
    
    .section-title {
      font-size: 1.75rem;
    }

    .section-title-description {
      font-size: 1.6rem;
    }
  }
  
  @media (max-width: 768px) {
    .container {
      padding: 2rem 0;
    }
    
    .intro-section {
      margin-bottom: 3rem;
    }
    
    .main-title {
      font-size: 2.25rem;
    }
    
    .intro-text {
      font-size: 1rem;
    }
    
    .cta-buttons {
      flex-direction: column;
      gap: 1rem;
    }
    
    .content-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .resources-grid {
      grid-template-columns: 1fr;
    }

    .collection-item {
      border-right: none !important;
      border-bottom: 1px solid var(--color-border) !important;
    }
    
    .collection-item:last-child {
      border-bottom: none !important;
    }
    
    .section-title {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    .subscribe-section {
      padding-left: 0;
      padding-top: 0;
    }

    .section-title-description {
      font-size: 2rem;
    }
  }
  
  @media (max-width: 480px) {
    .container {
      width: 80%;
      padding: 0rem 0;
    }
    .intro-section {
      margin-top: 4rem;
    }
    .content-grid {
      margin-bottom: 5rem;
      gap: 0rem;
    }
    .main-title {
      font-size: 2rem;
      margin-bottom: 1rem;
    }
    .intro-text {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }
    .collection-item {
      padding: 1.25rem;
    }
    .item-title {
      font-size: 1.1rem;
    }
    .item-desc {
      font-size: 0.9rem;
    }
  }
</style>